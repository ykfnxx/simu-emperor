# Province Agent Configuration
# 省份Agent系统配置文件

# ============================================
# LLM配置
# ============================================
llm:
  # 是否启用LLM（false则使用mock模式）
  enabled: true

  # API密钥（可以从环境变量读取：${ANTHROPIC_API_KEY}）
  api_key: "${ANTHROPIC_API_KEY}"

  # 使用的模型
  model: "claude-3-5-sonnet-20241022"
  # 可选模型：
  # - claude-3-5-sonnet-20241022 (最强，较慢)
  # - claude-3-5-haiku-20241022 (快速，便宜)
  # - claude-3-opus-20240229 (旧版最强)
  # - claude-3-haiku-20240307 (旧版快速)

  # 最大token数
  max_tokens: 4096

  # 温度（0.0-1.0，越低越确定）
  temperature: 0.3

  # 是否使用mock模式（测试用，不调用真实API）
  mock_mode: false

# ============================================
# Province Agent设置
# ============================================
province_agent:
  # 是否启用Province Agent系统
  enabled: true

  # Agent运行模式
  # - rule_based: 纯规则驱动
  # - llm_assisted: LLM辅助决策
  mode: "llm_assisted"

  # 行为执行配置
  behavior:
    # 是否允许行为自动执行
    auto_execute: true

    # 最大并行行为数
    max_behaviors: 3

    # 风险阈值
    risk_threshold: "medium"  # low, medium, high

# ============================================
# PerceptionAgent配置
# ============================================
perception_agent:
  # 历史数据窗口
  history:
    # 月度详细数据月数
    monthly_months: 1

    # 季度摘要季度数
    quarterly_quarters: 4

    # 年度摘要年数
    annual_years: 3

  # 关键事件索引
  critical_events:
    # 事件类别
    categories:
      - "rebellion"
      - "war"
      - "disaster"
      - "crisis"

    # 最大索引事件数
    max_events: 8

  # 摘要生成
  summary:
    # 是否使用LLM生成摘要
    use_llm: true

    # 摘要长度限制
    max_length: 100

# ============================================
# DecisionAgent配置
# ============================================
decision_agent:
  # 指令评估
  instruction:
    # 是否允许玩家指令
    allow_instructions: true

    # 指令超时时间（月）
    timeout_months: 3

  # 自主决策
  autonomous:
    # 是否启用自主决策
    enabled: true

    # 决策策略
    # - balanced: 平衡策略
    # - aggressive: 激进策略
    # - conservative: 保守策略
    strategy: "balanced"

# ============================================
# ExecutionAgent配置
# ============================================
execution_agent:
  # 行为执行
  execution:
    # 是否验证行为参数
    validate_params: true

    # 是否生成事件
    generate_events: true

  # 事件生成
  events:
    # 默认事件可见性
    default_visibility: "provincial"  # public, provincial, hidden

    # 是否记录行为历史
    log_history: true

# ============================================
# 日志配置
# ============================================
logging:
  # 日志级别
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

  # 是否输出详细日志
  verbose: true

  # 日志文件路径
  file: "province_agent.log"

  # 是否控制台输出
  console: true

# ============================================
# 数据库配置
# ============================================
database:
  # 数据库路径
  path: "game.db"

  # 是否启用WAL模式（提高并发性能）
  wal_mode: true

  # 连接池大小
  pool_size: 5

# ============================================
# 测试配置
# ============================================
testing:
  # 是否使用测试数据库
  use_test_db: false

  # 测试数据库路径
  test_db_path: "test_province_agent.db"

  # 是否在测试后清理
  cleanup_after_test: true
